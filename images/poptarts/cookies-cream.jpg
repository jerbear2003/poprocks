<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Cookies and Cream Pop Tart SVG -->
  <defs>
    <pattern id="cc-frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.7)"/>
    </pattern>
  </defs>
  
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#8b7355" stroke="#5a4a3a" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#7a6250"/>
  <circle cx="315" cy="110" r="6" fill="#7a6250"/>
  <circle cx="85" cy="290" r="6" fill="#7a6250"/>
  <circle cx="315" cy="290" r="6" fill="#7a6250"/>
  
  <!-- Cream filling with cookie pieces -->
  <rect x="85" y="120" width="230" height="160" fill="#f0f0f0" stroke="none"/>
  
  <!-- White frosting -->
  <rect x="75" y="100" width="250" height="30" fill="#ffffff" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#cc-frosting)" stroke="none" rx="4"/>
  
  <!-- Cookie pieces (dark circles) -->
  <circle cx="110" cy="150" r="8" fill="#3a2817" opacity="0.8"/>
  <circle cx="200" cy="140" r="7" fill="#3a2817" opacity="0.8"/>
  <circle cx="270" cy="155" r="8" fill="#3a2817" opacity="0.8"/>
  <circle cx="140" cy="210" r="6" fill="#3a2817" opacity="0.7"/>
  <circle cx="250" cy="220" r="7" fill="#3a2817" opacity="0.7"/>
  
  <!-- Cookie details (cream bits peeking out) -->
  <circle cx="110" cy="150" r="4" fill="#e8d5c4" opacity="0.6"/>
  <circle cx="200" cy="140" r="3.5" fill="#e8d5c4" opacity="0.6"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
