<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- French Toast Pop Tart SVG -->
  <defs>
    <pattern id="ft-frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.6)"/>
    </pattern>
  </defs>
  
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#d4a574" stroke="#8b4513" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#c9975f"/>
  <circle cx="315" cy="110" r="6" fill="#c9975f"/>
  <circle cx="85" cy="290" r="6" fill="#c9975f"/>
  <circle cx="315" cy="290" r="6" fill="#c9975f"/>
  
  <!-- French toast filling -->
  <rect x="85" y="120" width="230" height="160" fill="#c4a574" stroke="none"/>
  
  <!-- Cinnamon frosting -->
  <rect x="75" y="100" width="250" height="30" fill="#e8c89c" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#ft-frosting)" stroke="none" rx="4"/>
  
  <!-- Cinnamon swirl -->
  <path d="M 100 115 Q 150 120 200 115 T 300 115" stroke="#a0522d" stroke-width="2" fill="none" opacity="0.6"/>
  <path d="M 110 210 Q 160 215 210 210 T 310 210" stroke="#a0522d" stroke-width="1.5" fill="none" opacity="0.5"/>
  <circle cx="120" cy="130" r="2" fill="#a0522d" opacity="0.7"/>
  <circle cx="200" cy="150" r="2.5" fill="#a0522d" opacity="0.7"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
