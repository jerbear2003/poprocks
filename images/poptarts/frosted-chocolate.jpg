<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Frosted Chocolate Pop Tart SVG -->
  <defs>
    <pattern id="choc-frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.5)"/>
    </pattern>
  </defs>
  
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#8b7355" stroke="#5a4a3a" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#7a6250"/>
  <circle cx="315" cy="110" r="6" fill="#7a6250"/>
  <circle cx="85" cy="290" r="6" fill="#7a6250"/>
  <circle cx="315" cy="290" r="6" fill="#7a6250"/>
  
  <!-- Chocolate filling -->
  <rect x="85" y="120" width="230" height="160" fill="#3a2817" stroke="none"/>
  
  <!-- Chocolate frosting -->
  <rect x="75" y="100" width="250" height="30" fill="#6b4e3d" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#choc-frosting)" stroke="none" rx="4"/>
  
  <!-- Chocolate swirls and texture -->
  <circle cx="120" cy="115" r="3" fill="#4a3a2a" opacity="0.8"/>
  <circle cx="200" cy="108" r="2.5" fill="#4a3a2a" opacity="0.8"/>
  <circle cx="280" cy="120" r="3" fill="#4a3a2a" opacity="0.8"/>
  <circle cx="90" cy="200" r="2" fill="#5a4a3a" opacity="0.6"/>
  <circle cx="310" cy="210" r="2.5" fill="#5a4a3a" opacity="0.6"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.3)" stroke-width="1" rx="8"/>
</svg>
