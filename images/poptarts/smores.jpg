<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- S'mores Pop Tart SVG -->
  <defs>
    <pattern id="smores-frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.5)"/>
    </pattern>
  </defs>
  
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#8b7355" stroke="#5a4a3a" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#7a6250"/>
  <circle cx="315" cy="110" r="6" fill="#7a6250"/>
  <circle cx="85" cy="290" r="6" fill="#7a6250"/>
  <circle cx="315" cy="290" r="6" fill="#7a6250"/>
  
  <!-- Complex filling with chocolate and marshmallow layers -->
  <rect x="85" y="120" width="230" height="70" fill="#3a2817" stroke="none"/>
  <rect x="85" y="190" width="230" height="90" fill="#d4a574" stroke="none"/>
  
  <!-- Frosting/marshmallow top -->
  <rect x="75" y="100" width="250" height="30" fill="#e8d5c4" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#smores-frosting)" stroke="none" rx="4"/>
  
  <!-- Chocolate chips -->
  <circle cx="110" cy="150" r="3" fill="#663300" opacity="0.8"/>
  <circle cx="200" cy="155" r="3.5" fill="#663300" opacity="0.8"/>
  <circle cx="280" cy="145" r="3" fill="#663300" opacity="0.8"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
