<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Strawberry Pop Tart SVG -->
  <defs>
    <pattern id="frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.6)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="400" fill="#fbf5e9"/>
  
  <!-- Pop Tart pastry -->
  <rect x="75" y="100" width="250" height="200" fill="#d4a574" stroke="#8b4513" stroke-width="3" rx="8"/>
  
  <!-- Rounded corners emphasis -->
  <circle cx="85" cy="110" r="6" fill="#c9975f"/>
  <circle cx="315" cy="110" r="6" fill="#c9975f"/>
  <circle cx="85" cy="290" r="6" fill="#c9975f"/>
  <circle cx="315" cy="290" r="6" fill="#c9975f"/>
  
  <!-- Filling (strawberry red) -->
  <rect x="85" y="120" width="230" height="160" fill="#e74c3c" stroke="none"/>
  
  <!-- Frosting layer -->
  <rect x="75" y="100" width="250" height="30" fill="#ffb3ba" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#frosting)" stroke="none" rx="4"/>
  
  <!-- Decorative sprinkles/texture -->
  <circle cx="130" cy="115" r="3" fill="#ff69b4" opacity="0.7"/>
  <circle cx="200" cy="108" r="2" fill="#ff69b4" opacity="0.7"/>
  <circle cx="280" cy="120" r="2.5" fill="#ff69b4" opacity="0.7"/>
  
  <!-- Shadow/depth -->
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
