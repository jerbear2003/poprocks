<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Unfrosted Strawberry Pop Tart SVG -->
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#d4a574" stroke="#8b4513" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#c9975f"/>
  <circle cx="315" cy="110" r="6" fill="#c9975f"/>
  <circle cx="85" cy="290" r="6" fill="#c9975f"/>
  <circle cx="315" cy="290" r="6" fill="#c9975f"/>
  
  <!-- Strawberry filling (unfrosted - no frosting layer) -->
  <rect x="85" y="120" width="230" height="160" fill="#e74c3c" stroke="none"/>
  
  <!-- Texture marks for unfrosted -->
  <line x1="100" y1="150" x2="300" y2="150" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
  <line x1="100" y1="190" x2="300" y2="190" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
  <line x1="100" y1="230" x2="300" y2="230" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
  
  <!-- Strawberry details -->
  <circle cx="130" cy="120" r="3" fill="#ff69b4" opacity="0.7"/>
  <circle cx="200" cy="115" r="2.5" fill="#ff69b4" opacity="0.7"/>
  <circle cx="270" cy="125" r="3" fill="#ff69b4" opacity="0.7"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
