<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Wildberry Pop Tart SVG -->
  <defs>
    <pattern id="wild-frosting" patternUnits="userSpaceOnUse" width="4" height="4">
      <circle cx="2" cy="2" r="1" fill="rgba(255, 255, 255, 0.6)"/>
    </pattern>
  </defs>
  
  <rect width="400" height="400" fill="#fbf5e9"/>
  <rect x="75" y="100" width="250" height="200" fill="#d4a574" stroke="#8b4513" stroke-width="3" rx="8"/>
  
  <circle cx="85" cy="110" r="6" fill="#c9975f"/>
  <circle cx="315" cy="110" r="6" fill="#c9975f"/>
  <circle cx="85" cy="290" r="6" fill="#c9975f"/>
  <circle cx="315" cy="290" r="6" fill="#c9975f"/>
  
  <!-- Mixed wildberry filling -->
  <rect x="85" y="120" width="230" height="160" fill="#7b2d8f" stroke="none"/>
  
  <!-- Purple-pink frosting -->
  <rect x="75" y="100" width="250" height="30" fill="#c285d4" stroke="none" rx="4"/>
  <rect x="75" y="100" width="250" height="30" fill="url(#wild-frosting)" stroke="none" rx="4"/>
  
  <!-- Berry details -->
  <circle cx="120" cy="145" r="5" fill="#5a1a7a" opacity="0.8"/>
  <circle cx="200" cy="135" r="5.5" fill="#5a1a7a" opacity="0.8"/>
  <circle cx="270" cy="150" r="5" fill="#5a1a7a" opacity="0.8"/>
  <circle cx="150" cy="220" r="4" fill="#5a1a7a" opacity="0.6"/>
  <circle cx="250" cy="230" r="4.5" fill="#5a1a7a" opacity="0.6"/>
  
  <rect x="75" y="100" width="250" height="200" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="1" rx="8"/>
</svg>
